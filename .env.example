DISCORD_BOT_TOKEN=replace_me
DISCORD_GUILD_ID=replace_me
BOT_NAMESPACE=bot_showcase

# Runtime mode
# - mock: runs without real AI call (safe default)
# - external: expects your own private Engine integration
ENGINE_MODE=mock

# External Engine integration (only used when ENGINE_MODE=external)
ENGINE_PATH=/home/your-user/python/Engine
# Optional: document where your private Engine reads provider keys
ENGINE_API_ENV_FILE=/home/your-user/python/key/.env

# Optional behavior tuning
ASK_TURN_LIMIT=5
CHANNEL_HISTORY_LIMIT=5
MAX_CONTEXT_CHARS=4000
EXTERNAL_LOOKUP_ENABLED=0
